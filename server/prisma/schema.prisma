generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String     @id @default(uuid())
  name              String
  email             String     @unique
  password          String
  phoneNumber       String?
  role              Role
  isDeleted Boolean   @default(false)
deletedAt DateTime?
  verifyOtp         String?
  isAccountVerified Boolean    @default(false)
  resetOtp          String?
  resetOtpExpireAt  DateTime?
  verifyOtpExpireAt DateTime?
  createdAt         DateTime   @default(now())
  
  //relations
  craftsman         Craftsman?
  location          Location?

  tasks        Task[]
  reviews      Review[]
  adminInvites AdminInvite[]

  sentWarnings                Warning[]                 @relation("AdminWarnings")
  applications                Application[]
  handledReassignmentRequests TaskReassignmentRequest[]
}

model AdminInvite {
  id        String   @id @default(uuid())
  email     String   @unique
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  used      Boolean  @default(false)

  createdBy String // Admin who created this invite
  creator   User   @relation(fields: [createdBy], references: [id])
}

model Craftsman {
  userId String @id
  user   User   @relation(fields: [userId], references: [id])

  categoryId String?
  serviceId  String?
  queueOrder Int?

  experience Int?

  status       CraftsmanStatus @default(PENDING)
  isAvailable  Boolean         @default(true)
  warningLevel WarningLevel    @default(NONE)

  projects    Project[]
  assignments TaskAssignment[]
  reviews     Review[]
  category    Category?        @relation(fields: [categoryId], references: [id])
  service     Service?         @relation(fields: [serviceId], references: [id])

  taskCompletions TaskCompletion[]

  warnings Warning[]
  tasks    Task[]

  oldReassignmentRequests TaskReassignmentRequest[] @relation("OldCraftsmanReassignment")
  newReassignmentRequests TaskReassignmentRequest[] @relation("NewCraftsmanReassignment")

  @@unique([categoryId, serviceId, queueOrder])
  @@index([status])
  @@index([categoryId])
  @@index([serviceId])
  @@index([queueOrder])
  @@index([isAvailable])
}

model Application {
  id String @id @default(uuid())

  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  // Step 1
  categoryId String?
  serviceId  String?

  customCategory String?
  customService  String?

  yearsOfExperience Int?

  // Step 2
  city      String?
  address1  String?
  apartment String?

  // Step 3
  workingDays       Json?
  workingHours      Json?
  maxTravelDistance Int?

  // Step 4
  scenarioQA     Json?
  workBehaviorQA Json?

  // Progress tracking
  step   Int               @default(1)
  status ApplicationStatus @default(DRAFT)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  category Category? @relation(fields: [categoryId], references: [id])
  service  Service?  @relation(fields: [serviceId], references: [id])

  @@index([status])
  @@index([createdAt])
  @@index([updatedAt])
}

model Warning {
  id String @id @default(uuid())

  message   String
  createdAt DateTime @default(now())

  taskId String
  task   Task   @relation(fields: [taskId], references: [id])

  craftsmanId String
  craftsman   Craftsman @relation(fields: [craftsmanId], references: [userId])

  adminId String
  admin   User   @relation("AdminWarnings", fields: [adminId], references: [id])

  isRead Boolean @default(false)

  @@index([craftsmanId])
  @@index([createdAt])
}

model Location {
  id     String @id @default(uuid())
  userId String @unique

  city      String?
  address   String?
  apartment String?
  longitude Float?
  latitude  Float?

  user User @relation(fields: [userId], references: [id])
}

model Category {
  id       String    @id @default(uuid())
  name     String    @unique
  services Service[]

  craftsmen    Craftsman[]
  tasks        Task[]
  applications Application[]
  queue        CategoryAssignmentQueue[]
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt
}

model Service {
  id   String @id @default(uuid())
  name String

  categoryId   String
  category     Category      @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  tasks        Task[]
  applications Application[]

  craftsman Craftsman[]
  queue     CategoryAssignmentQueue[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name, categoryId])
}

model CategoryAssignmentQueue {
  id             String   @id @default(uuid())
  categoryId     String
  serviceId      String
  lastAssignedTo String?
  updatedAt      DateTime @updatedAt

  category Category @relation(fields: [categoryId], references: [id])
  service  Service  @relation(fields: [serviceId], references: [id])

  @@unique([categoryId, serviceId])
}

model Task {
  id          String @id @default(uuid())
  title       String
  description String

  location    String
  latitude    Float?
  longitude   Float?
  status      TaskStatus @default(PENDING)
  customerId  String
  craftsmanId String?

  categoryId String
  serviceId  String

  scheduledDate DateTime?
  completedAt   DateTime?

  lastAssignmentAttemptAt DateTime?
  becameUnassignableAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  category             Category                  @relation(fields: [categoryId], references: [id])
  service              Service                   @relation(fields: [serviceId], references: [id])
  customer             User                      @relation(fields: [customerId], references: [id])
  craftsman            Craftsman?                @relation(fields: [craftsmanId], references: [userId])
  assignments          TaskAssignment[]
  reviews              Review[]
  taskCompletions      TaskCompletion[]
  warnings             Warning[]
  reassignmentRequests TaskReassignmentRequest[]

  @@index([status])
  @@index([customerId])
  @@index([craftsmanId])
  @@index([categoryId])
  @@index([serviceId])
  @@index([createdAt])
  @@index([scheduledDate])
}

model TaskAssignment {
  id          String @id @default(uuid())
  taskId      String
  craftsmanId String

  status AssignmentStatus @default(PENDING)

  assignedAt  DateTime  @default(now())
  respondedAt DateTime?

  task      Task      @relation(fields: [taskId], references: [id])
  craftsman Craftsman @relation(fields: [craftsmanId], references: [userId])

  @@unique([taskId, craftsmanId])
  @@index([taskId])
  @@index([craftsmanId])
  @@index([status])
  @@index([assignedAt])
}

model TaskReassignmentRequest {
  id String @id @default(uuid())

  taskId String
  task   Task   @relation(fields: [taskId], references: [id])

  oldCraftsmanId String
  oldCraftsman   Craftsman @relation("OldCraftsmanReassignment", fields: [oldCraftsmanId], references: [userId])

  newCraftsmanId String?
  newCraftsman   Craftsman? @relation("NewCraftsmanReassignment", fields: [newCraftsmanId], references: [userId])

  adminId String?
  admin   User?   @relation(fields: [adminId], references: [id])

  reason String?

  status ReassignmentStatus @default(PENDING_ADMIN)

  adminMessage String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([taskId])
  @@index([status])
  @@index([oldCraftsmanId])
  @@index([newCraftsmanId])
}

enum ReassignmentStatus {
  PENDING_ADMIN
  PENDING_CRAFTSMAN
  ACCEPTED
  REJECTED
  CANCELLED
}

model Review {
  id String @id @default(uuid())

  taskId      String
  userId      String
  craftsmanId String

  rating                Int
  qualityRating         Int @default(5)
  punctualityRating     Int @default(5)
  communicationRating   Int @default(5)
  professionalismRating Int @default(5)
  cleanlinessRating     Int @default(5)
  priceFairnessRating   Int @default(5)

  detailedAverage Float @default(5)

  wouldRecommend Boolean  @default(true)
  wouldHireAgain Boolean  @default(true)
  issueTags      String[] @default([])

  comment   String?
  createdAt DateTime @default(now())

  task      Task      @relation(fields: [taskId], references: [id])
  craftsman Craftsman @relation(fields: [craftsmanId], references: [userId])
  user      User?     @relation(fields: [userId], references: [id])

  @@unique([taskId, userId])
  @@index([userId])
  @@index([craftsmanId])
  @@index([taskId])
  @@index([createdAt])
}

model Project {
  id          String @id @default(uuid())
  craftsmanId String

  title       String
  description String

  createdAt DateTime @default(now())

  craftsman Craftsman      @relation(fields: [craftsmanId], references: [userId])
  images    ProjectImage[]
}

model ProjectImage {
  id        String @id @default(uuid())
  projectId String

  imageUrl String

  project Project @relation(fields: [projectId], references: [id])
}

model TaskCompletion {
  id          String   @id @default(uuid())
  taskId      String   @unique
  craftsmanId String
  notes       String?
  completedAt DateTime @default(now())

  craftsman Craftsman   @relation(fields: [craftsmanId], references: [userId])
  task      Task        @relation(fields: [taskId], references: [id])
  images    TaskImage[]
}

model TaskImage {
  id               String @id @default(uuid())
  taskCompletionId String
  imageUrl         String

  completion TaskCompletion @relation(fields: [taskCompletionId], references: [id])
}

enum Role {
  CUSTOMER
  CRAFTSMAN
  SUPERADMIN
  ADMIN
}

enum TaskStatus {
  PENDING
  WAITING
  IN_PROGRESS
  COMPLETED
  CANCELLED
  UNASSIGNABLE
}

enum AssignmentStatus {
  PENDING
  ACCEPTED
  DECLINED
  TIMEOUT
  TRANSFERRED
}

enum CraftsmanStatus {
  SUSPENDED
  PENDING
  APPROVED
  REJECTED
}

enum WarningLevel {
  NONE
  LOW
  MEDIUM
  HIGH
}

enum ApplicationStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
}
