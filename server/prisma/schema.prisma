generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String     @id @default(uuid())
  name              String
  email             String     @unique
  password          String
  phoneNumber       String?
  role              Role
  verifyOtp         String?
  isAccountVerified Boolean    @default(false)
  resetOtp          String?
  resetOtpExpireAt  DateTime?
  verifyOtpExpireAt DateTime?
  createdAt         DateTime   @default(now())
  //relations
  craftsman         Craftsman?
  location          Location?

  tasks        Task[]
  reviews      Review[]
  adminInvites AdminInvite[]

  sentWarnings Warning[]     @relation("AdminWarnings")
  applications Application[]
}

model AdminInvite {
  id        String   @id @default(uuid())
  email     String   @unique
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  used      Boolean  @default(false)

  createdBy String // Admin who created this invite
  creator   User   @relation(fields: [createdBy], references: [id])
}

model Craftsman {
  userId String @id
  user   User   @relation(fields: [userId], references: [id])

  categoryId String?
  serviceId  String?
  queueOrder Int?

  experience Int?

  status       CraftsmanStatus @default(PENDING)
  isAvailable  Boolean         @default(true)
  warningLevel WarningLevel    @default(NONE)

  projects    Project[]
  assignments TaskAssignment[]
  reviews     Review[]
  category    Category?        @relation(fields: [categoryId], references: [id])
  service     Service?         @relation(fields: [serviceId], references: [id])

  taskCompletions TaskCompletion[]

  warnings Warning[]
  tasks    Task[]

  @@unique([categoryId, queueOrder])
}

model Application {
  id String @id @default(uuid())

  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  // Step 1
  categoryId        String?
  yearsOfExperience Int?

  // Step 2
  city      String?
  address1  String?
  apartment String?

  // Step 3
  workingDays       Json?
  workingHours      Json?
  maxTravelDistance Int?

  // Step 4
  scenarioQA     Json?
  workBehaviorQA Json?

  // Progress tracking
  step   Int               @default(1)
  status ApplicationStatus @default(DRAFT)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  category Category? @relation(fields: [categoryId], references: [id])
}

model Warning {
  id String @id @default(uuid())

  message   String
  createdAt DateTime @default(now())

  taskId String
  task   Task   @relation(fields: [taskId], references: [id])

  craftsmanId String
  craftsman   Craftsman @relation(fields: [craftsmanId], references: [userId])

  adminId String
  admin   User   @relation("AdminWarnings", fields: [adminId], references: [id])

  isRead Boolean @default(false)
}

model Location {
  id     String @id @default(uuid())
  userId String @unique

  city      String?
  address   String?
  apartment String?
  longitude Float?
  latitude  Float?

  user User @relation(fields: [userId], references: [id])
}

model Category {
  id       String    @id @default(uuid())
  name     String    @unique
  services Service[]

  craftsmen    Craftsman[]
  tasks        Task[]
  applications Application[]
  queue        CategoryAssignmentQueue?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Service {
  id   String @id @default(uuid())
  name String

  categoryId String
  category   Category    @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  tasks      Task[]
  craftsman  Craftsman[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name, categoryId])
}

model CategoryAssignmentQueue {
  categoryId     String   @id
  lastAssignedTo String?
  updatedAt      DateTime @updatedAt

  category Category @relation(fields: [categoryId], references: [id])
}

model Task {
  id          String  @id @default(uuid())
  title       String
  description String

  location  String
  latitude  Float?
  longitude Float?
  status    TaskStatus @default(PENDING)
  customerId  String
  craftsmanId String?

  categoryId  String
  serviceId   String
  

  scheduledDate DateTime?
  completedAt   DateTime?


  createdAt DateTime   @default(now())
  updatedAt   DateTime @updatedAt

  category        Category         @relation(fields: [categoryId], references: [id])
  service         Service          @relation(fields: [serviceId], references: [id])
  customer        User             @relation(fields: [customerId], references: [id])
  craftsman       Craftsman?       @relation(fields: [craftsmanId], references: [userId])
  assignments     TaskAssignment[]
  reviews         Review[]
  taskCompletions TaskCompletion[]
  warnings        Warning[]
}

model TaskAssignment {
  id          String @id @default(uuid())
  taskId      String
  craftsmanId String

  status AssignmentStatus @default(PENDING)

  assignedAt  DateTime  @default(now())
  respondedAt DateTime?

  task      Task      @relation(fields: [taskId], references: [id])
  craftsman Craftsman @relation(fields: [craftsmanId], references: [userId])

  @@unique([taskId, craftsmanId])
}

model Review {
  id String @id @default(uuid())

  taskId      String
  userId      String
  craftsmanId String

  rating    Int
  qualityRating         Int      @default(5)
  punctualityRating     Int      @default(5)
  communicationRating   Int      @default(5)
  professionalismRating Int      @default(5)
  cleanlinessRating     Int      @default(5)
  priceFairnessRating   Int      @default(5)

  detailedAverage       Float    @default(5)
  
  wouldRecommend        Boolean  @default(true)
  wouldHireAgain        Boolean  @default(true)
  issueTags             String[] @default([])

  comment   String?
  createdAt DateTime @default(now())

  task      Task      @relation(fields: [taskId], references: [id])
  craftsman Craftsman @relation(fields: [craftsmanId], references: [userId])
  user      User?     @relation(fields: [userId], references: [id])

  //npx prisma migrate dev --name add_unique_review_constraint
  @@unique([taskId, userId])
}

model Project {
  id          String @id @default(uuid())
  craftsmanId String

  title       String
  description String

  createdAt DateTime @default(now())

  craftsman Craftsman      @relation(fields: [craftsmanId], references: [userId])
  images    ProjectImage[]
}

model ProjectImage {
  id        String @id @default(uuid())
  projectId String

  imageUrl String

  project Project @relation(fields: [projectId], references: [id])
}

model TaskCompletion {
  id          String   @id @default(uuid())
  taskId      String   @unique
  craftsmanId String
  notes       String?
  completedAt DateTime @default(now())

  craftsman Craftsman   @relation(fields: [craftsmanId], references: [userId])
  task      Task        @relation(fields: [taskId], references: [id])
  images    TaskImage[]
}

model TaskImage {
  id               String @id @default(uuid())
  taskCompletionId String
  imageUrl         String

  completion TaskCompletion @relation(fields: [taskCompletionId], references: [id])
}

enum Role {
  CUSTOMER
  CRAFTSMAN
  SUPERADMIN
  ADMIN
}

enum TaskStatus {
  PENDING
  WAITING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum AssignmentStatus {
  PENDING
  ACCEPTED
  DECLINED
  TIMEOUT
}

enum CraftsmanStatus {
  SUSPENDED
  PENDING
  APPROVED
  REJECTED
}

enum WarningLevel {
  NONE
  LOW
  MEDIUM
  HIGH
}

enum ApplicationStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
}
